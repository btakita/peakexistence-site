{
  "name": "@btakita/peakexistence-site",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bun build.ts",
    "clear": "rm -rf ./dist",
    "dev": "bun run dev:sourcemap__resolve__bun",
    "dev:raw": "bun index.ts",
    "dev:sourcemap__resolve__bun": "sourcemap__resolve__bun -f index.ts",
    "db:drop": "drizzle-kit drop",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:migrate": "bun ./db/migrate.ts",
    "db:push": "drizzle-config push:sqlite",
    "start": "sourcemap__resolve__bun -f start.ts",
    "clean": "rm -rf ./dist"
  },
  "dependencies": {
    "@btakita/ui--server--peakexistence": "workspace: *",
    "@rappstack/domain--server": "workspace:*",
    "@rappstack/domain--server--auth": "workspace:*",
    "aos": "^2.3.4",
    "cssnano": "^6.1.0",
    "ctx-core": "^6.5.5",
    "drizzle-kit": "^0.20.14",
    "drizzle-orm": "^0.30.1",
    "elysia": "^0.8.17",
    "esbuild-plugin-esmfile": "^0.2.0",
    "esmcss": "^0.2.3",
    "relementjs": "^0.74.5",
    "relysjs": "^1.16.4",
    "tailwindcss-noscript": "^2.0.1"
  },
  "devDependencies": {
    "@btakita/dev-bin": "workspace:*",
    "@ctx-core/preprocess": "^0.1.2",
    "@rebuildjs/tailwindcss": "^0.8.61",
    "@tailwindcss/forms": "^0.5.7",
    "@types/aos": "^3.0.7",
    "bun-types": "latest",
    "esbuild-style-plugin": "^1.6.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1"
  },
  "peerDependencies": {
    "typescript": "^5.4.2"
  }
}