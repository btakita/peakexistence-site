{
  "name": "@btakita/peakexistence-site",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bun build.ts",
    "clean": "rm -rf ./dist",
    "dev": "bun run dev:sourcemap__resolve__bun",
    "dev:raw": "bun index.ts",
    "dev:sourcemap__resolve__bun": "sourcemap__resolve__bun -f index.ts",
    "db:drop": "drizzle-kit drop",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:migrate": "bun ./db/migrate.ts",
    "db:push": "drizzle-config push:sqlite",
    "start": "sourcemap__resolve__bun -f start.ts"
  },
  "dependencies": {
    "@btakita/domain--server--peakexistence": "workspace:*",
    "@btakita/ui--server--peakexistence": "workspace:*",
    "@rappstack/domain--any--blog": "^0.1.0",
    "@rappstack/domain--server": "^0.1.0",
    "@rappstack/domain--server--auth": "^0.1.0",
    "@rappstack/domain--server--blog": "^0.1.0",
    "@rappstack/ui--any": "^0.1.0",
    "@rappstack/ui--browser--blog": "^0.1.0",
    "@rappstack/ui--server": "^0.1.0",
    "@rappstack/ui--server--blog": "^0.1.0",
    "@sinclair/typebox": "^0.34.48",
    "@tailwindcss/typography": "^0.5.13",
    "aos": "^2.3.4",
    "cssnano": "^7.0.4",
    "ctx-core": "^7.2.27",
    "drizzle-kit": "^0.23.0",
    "drizzle-orm": "^0.32.0",
    "elysia": "^1.4.27",
    "esbuild-plugin-esmfile": "^0.2.9",
    "esmcss": "^0.2.12",
    "highlight.js": "^11.10.0",
    "marked": "^13.0.2",
    "marked-gfm-heading-id": "^4.0.0",
    "relementjs": "^0.80.26",
    "relysjs": "^1.21.75",
    "tailwindcss-noscript": "^2.0.1"
  },
  "devDependencies": {
    "@btakita/dev-bin": "^0.1.0",
    "@ctx-core/preprocess": "^0.1.3",
    "@rebuildjs/tailwindcss": "^0.10.49",
    "@tailwindcss/forms": "^0.5.7",
    "@types/aos": "^3.0.7",
    "bun-types": "latest",
    "esbuild-style-plugin": "^1.6.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4"
  },
  "peerDependencies": {
    "typescript": "^5.5.3"
  }
}