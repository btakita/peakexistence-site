{
  "name": "@btakita/peakexistence-site",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bun build.ts",
    "clean": "rm -rf ./dist",
    "dev": "bun run dev:sourcemap__resolve__bun",
    "dev:raw": "bun index.ts",
    "dev:sourcemap__resolve__bun": "sourcemap__resolve__bun -f index.ts",
    "db:drop": "drizzle-kit drop",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:migrate": "bun ./db/migrate.ts",
    "db:push": "drizzle-config push:sqlite",
    "start": "sourcemap__resolve__bun -f start.ts"
  },
  "dependencies": {
    "@btakita/domain--server--peakexistence": "workspace:*",
    "@btakita/ui--server--peakexistence": "workspace: *",
    "@rappstack/domain--server": "workspace:*",
    "@rappstack/domain--server--auth": "workspace:*",
    "@rappstack/ui--any": "workspace:*",
    "@tailwindcss/typography": "^0.5.13",
    "aos": "^2.3.4",
    "cssnano": "^7.0.1",
    "ctx-core": "^7.2.4",
    "drizzle-kit": "^0.20.18",
    "drizzle-orm": "^0.30.10",
    "elysia": "^1.0.16",
    "esbuild-plugin-esmfile": "^0.2.3",
    "esmcss": "^0.2.6",
    "marked": "^12.0.2",
    "marked-gfm-heading-id": "^3.1.3",
    "relementjs": "^0.80.4",
    "relysjs": "^1.21.21",
    "tailwindcss-noscript": "^2.0.1"
  },
  "devDependencies": {
    "@btakita/dev-bin": "workspace:*",
    "@ctx-core/preprocess": "^0.1.3",
    "@rebuildjs/tailwindcss": "^0.10.13",
    "@tailwindcss/forms": "^0.5.7",
    "@types/aos": "^3.0.7",
    "bun-types": "latest",
    "esbuild-style-plugin": "^1.6.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3"
  },
  "peerDependencies": {
    "typescript": "^5.4.5"
  }
}